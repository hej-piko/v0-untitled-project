@{
}
@using EsportsTournament.Models
@model IEnumerable<AspNetUsers>

<h2>All User Accounts</h2>
<table class="table">
    <thead>
        <tr>
            <th>Username</th>
            <th>Email</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.UserName</td>
                <td>@user.Email</td>
                <td>
                    <!-- Optional actions like View, Edit, Delete -->
                    <a asp-action="Details" asp-route-id="@user.Id">View</a>
                </td>
            </tr>
        }
    </tbody>
</table>