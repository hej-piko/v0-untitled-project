@model EsportsTournament.Models.Tournament
@using Microsoft.AspNetCore.Identity
@using EsportsTournament.Models
@inject UserManager<AspNetUsers> UserManager
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = Model.Name;
    var currentUser = await UserManager.GetUserAsync(User);
    var isCreator = currentUser != null && Model.CreatorId == currentUser.Id;
    var isParticipant = currentUser != null && Model.Participants.Any(p => p.UserId == currentUser.Id);
    var canJoin = currentUser != null && Model.IsOpen && !isParticipant && Model.Participants.Count < Model.MaxParticipants;
}
<style>
    :root {
    --gaming-dark: #07171B;
    --gaming-teal-dark: #184655;
    --gaming-teal: #35707F;
    --gaming-teal-light: #8AC0BA;
    --gaming-beige: #E2D9B6;
    --gaming-gold: #E1A100;
    --gaming-amber: #CF8500;
    --gaming-orange: #B35C00;
    --gaming-red-orange: #992D0B;
    --gaming-red-dark: #7C2321;
    }
    body {
    background: linear-gradient(135deg, var(--gaming-dark) 70%, var(--gaming-teal-dark) 100%);
    color: var(--gaming-beige);
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }
    .details-outer {
    min-height: 80vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100vw;
    box-sizing: border-box;
    padding-top: 2.5rem;
    padding-bottom: 10rem;
    }
    .details-container {
    max-width: 80%;
    width: 100%;
    margin: 0;
    background: linear-gradient(135deg, var(--gaming-teal), var(--gaming-teal-light));
    border-radius: 18px;
    box-shadow: 0 8px 32px var(--gaming-gold), 0 0 0 4px var(--gaming-dark);
    padding: 2.5rem 2rem 2rem 2rem;
    color: var(--gaming-dark);
    display: flex;
    flex-direction: column;
    align-items: center;
    }
    .details-title {
    color: var(--gaming-gold);
    font-size: 2rem;
    font-weight: bold;
    letter-spacing: 2px;
    margin-bottom: 1.5rem;
    text-align: center;
    word-break: break-word;
    }
    .details-label {
    color: var(--gaming-gold);
    font-weight: 600;
    margin-bottom: 0.3rem;
    margin-right: 0.5rem;
    align-self: flex-start;
    }
    .details-value {
    color: var(--gaming-dark);
    font-weight: 500;
    margin-bottom: 1rem;
    word-break: break-word;
    align-self: flex-start;
    }
    .details-status {
    font-weight: bold;
    color: var(--gaming-orange);
    margin-bottom: 1rem;
    align-self: flex-start;
    }
    .details-participants {
    margin-bottom: 1.5rem;
    color: var(--gaming-dark);
    align-self: flex-start;
    }
    .btn-details-action {
    text-decoration:none;
    background: linear-gradient(90deg, var(--gaming-gold), var(--gaming-orange));
    color: var(--gaming-dark) !important;
    border: none;
    border-radius: 10px;
    font-size: 1.1rem;
    font-weight: bold;
    cursor: pointer;
    box-shadow: 0 2px 8px var(--gaming-orange);
    transition: background 0.2s, box-shadow 0.2s;
    padding: 0.85rem 2.5rem;
    margin: 1.2rem auto 0 auto;
    display: block;
    }
    .btn-details-action:hover {
    background: linear-gradient(90deg, var(--gaming-amber), var(--gaming-gold));
    box-shadow: 0 4px 16px var(--gaming-gold);
    color: var(--gaming-dark) !important;
    }
    .alert-success, .alert-danger {
    max-width: 480px;
    margin: 0 auto 1.5rem auto;
    border-radius: 8px;
    font-weight: 500;
    }
    .details-card {
    width: 100%;
    background: transparent;
    border: none;
    box-shadow: none;
    margin-top: 2rem;
    margin-bottom: 0;
    }
    .details-card .card-header {
    background: linear-gradient(90deg, var(--gaming-teal-dark), var(--gaming-teal));
    color: var(--gaming-gold);
    border-radius: 12px 12px 0 0;
    font-weight: bold;
    font-size: 1.1rem;
    letter-spacing: 1px;
    padding: 1rem 1.5rem;
    border-bottom: none;
    }
    .details-card .card-body {
    background: transparent;
    color: var(--gaming-dark);
    border-radius: 0 0 12px 12px;
    padding: 1.5rem 1.2rem;
    }
    .list-group-item {
    background: var(--gaming-teal-light);
    color: var(--gaming-dark);
    border: none;
    border-radius: 8px;
    margin-bottom: 0.5rem;
    font-weight: 500;
    }
    .badge-primary {
    background: var(--gaming-gold);
    color: var(--gaming-dark);
    font-weight: bold;
    }
    .details-card-participants {
    width: 100%;
    background: transparent;
    border: none;
    box-shadow: none;
    margin-top: 2rem;
    margin-bottom: 0;
    max-height: 320px;
    overflow-y: auto;
    }
    .details-card-participants .card-header {
    background: linear-gradient(90deg, var(--gaming-teal-dark), var(--gaming-teal));
    color: var(--gaming-gold);
    border-radius: 12px 12px 0 0;
    font-weight: bold;
    font-size: 1.1rem;
    letter-spacing: 1px;
    padding: 1rem 1.5rem;
    border-bottom: none;
    }
    .details-card-participants .card-body {
    background: transparent;
    color: var(--gaming-dark);
    border-radius: 0 0 12px 12px;
    padding: 1.5rem 1.2rem;
    }
    .btn-back-list {
    background: linear-gradient(90deg, var(--gaming-gold), var(--gaming-orange));
    color: var(--gaming-dark) !important;
    border: none;
    border-radius: 10px;
    font-size: 1.1rem;
    font-weight: bold;
    cursor: pointer;
    box-shadow: 0 2px 8px var(--gaming-orange);
    transition: background 0.2s, box-shadow 0.2s;
    padding: 0.7rem 2.2rem;
    margin: 0 auto 1rem auto;
    display: block;
    text-align: center;
    text-decoration: none;
    width: fit-content;
    }
    .btn-back-list:hover {
    background: linear-gradient(90deg, var(--gaming-amber), var(--gaming-gold));
    box-shadow: 0 4px 16px var(--gaming-gold);
    color: var(--gaming-dark) !important;
    text-decoration: none;
    }
</style>
<div class="details-outer">
    <div class="details-container">
        <div class="mt-3">
            <a asp-action="Index" asp-controller="Home" class="btn-back-list">Back to List</a>
        </div>
        <div class="details-title">@Model.Name</div>
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">
                @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">
                @TempData["Error"]
            </div>
        }
        <div class="details-label">Game:</div>
        <div class="details-value">@Model.Game</div>
        <div class="details-label">Description:</div>
        <div class="details-value">@Model.Description</div>
        <div class="details-label">Start Date:</div>
        <div class="details-value">@Model.StartDate.ToString("MMM dd, yyyy HH:mm")</div>
        <div class="details-label">Created By:</div>
        <div class="details-value">@Model.Creator.UserName</div>
        <div class="details-label">Status:</div>
        <div class="details-status">@(Model.IsOpen ? "Open for Registration" : "Registration Closed")</div>
        <div class="details-label">Participants:</div>
        <div class="details-participants">@Model.Participants.Count / @Model.MaxParticipants</div>
        @if (canJoin)
        {
            <form asp-controller="Tournaments" asp-action="Join" asp-route-id="@Model.Id" method="post" style="width:100%;">
                <button type="submit" class="btn-details-action">Join Tournament</button>
            </form>
        }
        else if (isParticipant)
        {
            <div class="alert alert-info">You are registered for this tournament.</div>
        }
        @if (isCreator)
        {

            @if (Model.IsOpen)
            {
                <div class="mt-3">
                    @* <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-block">Edit Tournament</a> *@
                    <form asp-action="StartTournament" asp-route-id="@Model.Id" method="post" class="mt-2">
                        <button type="submit" class="btn-details-action">Start Tournament</button>
                    </form>
                </div>
            }
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-details-action">Edit Tournament</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn-details-action">Delete Tournament</a>
        }

        <div class="card details-card-participants">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0">Participants</h5>
            </div>
            <div class="card-body">
                @if (Model.Participants.Any())
                {
                    <ul class="list-group">
                        @foreach (var participant in Model.Participants.OrderBy(p => p.JoinedAt))
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                @participant.User.UserName
                                @if (!Model.IsOpen && participant.Seed.HasValue)
                                {
                                    <span class="badge badge-primary badge-pill">Seed #@participant.Seed</span>
                                }
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-center">No participants yet.</p>
                }
            </div>
        </div>
        <div class="card details-card">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0">Tournament Bracket</h5>
            </div>
            <div class="card-body">
                @if (!Model.IsOpen && Model.Matches.Any())
                {
                    <div class="tournament-bracket">
                        @{
                            var rounds = Model.Matches.Select(m => m.Round).Distinct().OrderBy(r => r).ToList();
                            var maxRound = rounds.Max();
                        }

                        <div class="bracket-container">
                            @foreach (var round in rounds)
                            {
                                <div class="round">
                                    <h5 class="round-title">
                                        @if (round == 1) { <span>First Round</span> }
                                        else if (round == maxRound) { <span>Final</span> }
                                        else if (round == maxRound - 1) { <span>Semifinals</span> }
                                        else if (round == maxRound - 2) { <span>Quarterfinals</span> }
                                        else { <span>Round @round</span> }
                                    </h5>
                                    
                                    @foreach (var match in Model.Matches.Where(m => m.Round == round).OrderBy(m => m.MatchNumber))
                                    {
                                        <div class="match @(match.IsCompleted ? "completed" : "")">
                                            <div class="match-upper @(match.WinnerId == match.Participant1Id ? "winner" : "")">
                                                @if (match.Participant1Id.HasValue)
                                                {
                                                    var p1 = Model.Participants.FirstOrDefault(p => p.Id == match.Participant1Id);
                                                    <span>@p1.User.UserName</span>
                                                }
                                                else
                                                {
                                                    <span>TBD</span>
                                                }
                                            </div>
                                            <div class="match-lower @(match.WinnerId == match.Participant2Id ? "winner" : "")">
                                                @if (match.Participant2Id.HasValue)
                                                {
                                                    var p2 = Model.Participants.FirstOrDefault(p => p.Id == match.Participant2Id);
                                                    <span>@p2.User.UserName</span>
                                                }
                                                else
                                                {
                                                    <span>TBD</span>
                                                }
                                            </div>
                                            
                                            @if (isCreator && !match.IsCompleted && match.Participant1Id.HasValue && match.Participant2Id.HasValue)
                                            {
                                                <div class="match-actions">
                                                    <form asp-action="UpdateMatch" method="post">
                                                        <input type="hidden" name="matchId" value="@match.Id" />
                                                        <input type="hidden" name="tournamentId" value="@Model.Id" />
                                                        <div class="btn-group btn-group-sm">
                                                            <button type="submit" name="winnerId" value="@match.Participant1Id" class="btn btn-outline-primary">
                                                                P1 Wins
                                                            </button>
                                                            <button type="submit" name="winnerId" value="@match.Participant2Id" class="btn btn-outline-primary">
                                                                P2 Wins
                                                            </button>
                                                        </div>
                                                    </form>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
                else if (!Model.IsOpen)
                {
                    <p class="text-center">Bracket is being generated...</p>
                }
                else
                {
                    <p class="text-center">Tournament hasn't started yet. Bracket will be generated when the tournament begins.</p>
                }
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="~/css/details.css" />
@section Styles {
    <style>
        .tournament-bracket {
            overflow-x: auto;
            padding: 20px 0;
        }
        
        .bracket-container {
            display: flex;
            justify-content: flex-start;
            min-width: 100%;
        }
        
        .round {
            display: flex;
            flex-direction: column;
            margin-right: 40px;
            min-width: 200px;
        }
        
        .round-title {
            text-align: center;
            margin-bottom: 15px;
            font-weight: bold;
        }
        
        .match {
            display: flex;
            flex-direction: column;
            margin-bottom: 15px;
            border: 1px solid #ddd;
            border-radius: 4px;
            overflow: hidden;
        }
        
        .match.completed {
            background-color: #f8f9fa;
        }
        
        .match-upper, .match-lower {
            padding: 8px 12px;
            border-bottom: 1px solid #ddd;
        }
        
        .match-upper.winner, .match-lower.winner {
            background-color: #d4edda;
            font-weight: bold;
        }
        
        .match-actions {
            padding: 8px;
            background-color: #f8f9fa;
            text-align: center;
        }
    </style>
}
