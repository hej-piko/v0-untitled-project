@model EsportsTournament.Models.CreateTournamentViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Create Tournament";
    Layout = "_Layout"; 
}
<style>
    :root {
        --gaming-dark: #07171B;
        --gaming-teal-dark: #184655;
        --gaming-teal: #35707F;
        --gaming-teal-light: #8AC0BA;
        --gaming-beige: #E2D9B6;
        --gaming-gold: #E1A100;
        --gaming-amber: #CF8500;
        --gaming-orange: #B35C00;
        --gaming-red-orange: #992D0B;
        --gaming-red-dark: #7C2321;
    }
    body {
        background: linear-gradient(135deg, var(--gaming-dark) 70%, var(--gaming-teal-dark) 100%);
        color: var(--gaming-beige);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }
    .create-outer {
        min-height: 80vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        width: 100vw;
        box-sizing: border-box;
        padding-top: 2.5rem;
    }
    .create-container {
        max-width: 480px;
        width: 100%;
        margin: 0 auto;
        background: linear-gradient(135deg, var(--gaming-teal), var(--gaming-teal-light));
        border-radius: 18px;
        box-shadow: 0 8px 32px var(--gaming-gold), 0 0 0 4px var(--gaming-dark);
        padding: 2.5rem 2rem 2rem 2rem;
        color: var(--gaming-dark);
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    .create-title {
        color: var(--gaming-gold);
        font-size: 2rem;
        font-weight: bold;
        letter-spacing: 2px;
        margin-bottom: 1.5rem;
        text-align: center;
    }
    form {
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    .form-group {
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        margin-bottom: 1rem;
    }
    .form-group label {
        align-self: flex-start;
        color: var(--gaming-gold);
        font-weight: 600;
        margin-bottom: 0.3rem;
        margin-left: 0.5rem;
    }
    .form-control, textarea.form-control {
        width: 90%;
        margin-left: auto;
        margin-right: auto;
        background: var(--gaming-teal-dark);
        color: var(--gaming-beige);
        border: 1.5px solid var(--gaming-gold);
        border-radius: 10px;
        padding: 0.7rem 1rem;
        font-size: 1rem;
        box-shadow: 0 2px 8px var(--gaming-dark);
        transition: border 0.2s, box-shadow 0.2s, background 0.2s;
    }
    .form-control:focus, textarea.form-control:focus {
        border: 1.5px solid var(--gaming-orange);
        background: var(--gaming-teal);
        color: var(--gaming-gold);
        outline: none;
        box-shadow: 0 4px 16px var(--gaming-gold);
    }
    .form-check-input {
        margin-left: 0.5rem;
        background: var(--gaming-teal-dark);
        border: 1.5px solid var(--gaming-gold);
        accent-color: var(--gaming-orange);
    }
    .btn-create {
        margin-left: auto;
        margin-right: auto;
        display: block;
        background: linear-gradient(90deg, var(--gaming-gold), var(--gaming-orange));
        color: var(--gaming-dark) !important;
        border: none;
        border-radius: 10px;
        font-size: 1.1rem;
        font-weight: bold;
        cursor: pointer;
        box-shadow: 0 2px 8px var(--gaming-orange);
        transition: background 0.2s, box-shadow 0.2s;
        padding: 0.85rem 2.5rem;
    }
    .btn-create:hover {
        background: linear-gradient(90deg, var(--gaming-amber), var(--gaming-gold));
        box-shadow: 0 4px 16px var(--gaming-gold);
        color: var(--gaming-dark) !important;
    }
    .cancel-link {
        text-align: center;
        color: var(--gaming-orange);
        font-weight: 600;
        margin-top: 1.5rem;
        text-decoration: none;
        transition: color 0.2s;
    }
    .cancel-link:hover {
        color: var(--gaming-gold);
        text-decoration: underline;
    }
</style>
<div class="create-outer">
    <div class="create-container">
        <div class="create-title">Create Tournament</div>
        <form asp-controller="Tournaments" asp-action="Create" method="post" style="width:100%">
            <div class="form-group">
                <label for="Name" class="control-label">Name</label>
                <input name="Name" class="form-control" />
                <span class="text-danger"></span>
            </div>
            <div class="form-group">
                <label for="Description" class="control-label">Description</label>
                <textarea name="Description" class="form-control"></textarea>
                <span class="text-danger"></span>
            </div>
            <div class="form-group">
                <label for="Game" class="control-label">Game</label>
                <input name="Game" class="form-control" />
                <span class="text-danger"></span>
            </div>
            <div class="form-group">
                <label for="StartDate" class="control-label">Start Date</label>
                <input name="StartDate" class="form-control" type="datetime-local" />
                <span class="text-danger"></span>
            </div>
            <div class="form-group">
                <label for="MaxParticipants" class="control-label">Max Participants</label>
                <input name="MaxParticipants" class="form-control" />
                <span class="text-danger"></span>
            </div>
            <div class="form-group-check" style="display:flex; align-items:center; color: black; margin-bottom: 1rem;">
                <input name="IsOpen" type="checkbox" class="form-check-input" id="IsOpenCheck" />
                <label for="IsOpenCheck" class="control-label mb-0">Open</label>
                <span class="text-danger"></span>
            </div>
            <button type="submit" class="btn-create">Create Tournament</button>
        </form>
        <a href="@Url.Action("Index", "Home")" class="cancel-link">Cancel</a>
    </div>
</div>
