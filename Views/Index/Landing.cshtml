@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "Home Page";
}
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        :root {
            --gaming-dark: #07171B;
            --gaming-teal-dark: #184655;
            --gaming-teal: #35707F;
            --gaming-teal-light: #8AC0BA;
            --gaming-beige: #E2D9B6;
            --gaming-gold: #E1A100;
            --gaming-amber: #CF8500;
            --gaming-orange: #B35C00;
            --gaming-red-orange: #992D0B;
            --gaming-red-dark: #7C2321;
        }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, var(--gaming-dark) 70%, var(--gaming-teal-dark) 100%);
            color: var(--gaming-beige);
            min-height: 100vh;
        }
        .navbar {
            background: linear-gradient(90deg, var(--gaming-dark), var(--gaming-teal-dark));
            box-shadow: 0 2px 8px rgba(0,0,0,0.5);
        }
        .navbar-brand {
            font-weight: bold;
            color: var(--gaming-gold) !important;
            letter-spacing: 2px;
            font-size: 2rem;
            text-shadow: 0 2px 8px var(--gaming-orange);
        }
        .navbar-nav .nav-link {
            color: var(--gaming-beige) !important;
            margin-right: 1rem;
            transition: color 0.2s;
        }
        .navbar-nav .nav-link:hover, .navbar-nav .nav-link.active {
            color: var(--gaming-gold) !important;
        }
        .btn-primary {
            background: linear-gradient(90deg, var(--gaming-gold), var(--gaming-orange));
            border: none;
            color: var(--gaming-dark);
            font-weight: bold;
            box-shadow: 0 2px 8px var(--gaming-orange);
            transition: background 0.2s, box-shadow 0.2s;
        }
        .btn-primary:hover {
            background: linear-gradient(90deg, var(--gaming-amber), var(--gaming-gold));
            box-shadow: 0 4px 16px var(--gaming-gold);
            color: var(--gaming-dark);
        }
        .hero {
            background: linear-gradient(135deg, var(--gaming-teal-dark), var(--gaming-teal));
            color: var(--gaming-beige);
            padding: 5rem 0;
            margin-bottom: 2rem;
            border-bottom: 4px solid var(--gaming-gold);
            box-shadow: 0 8px 32px rgba(0,0,0,0.4);
        }
        .hero h1 {
            text-shadow: 0 4px 24px var(--gaming-gold);
        }
        .feature-card {
            border: none;
            border-radius: 16px;
            background: linear-gradient(135deg, var(--gaming-teal), var(--gaming-teal-light));
            box-shadow: 0 4px 16px rgba(0,0,0,0.3), 0 0 0 4px var(--gaming-dark);
            transition: transform 0.3s, box-shadow 0.3s;
            height: 100%;
            color: var(--gaming-dark);
        }
        .feature-card:hover {
            transform: scale(1.04) translateY(-5px);
            box-shadow: 0 8px 32px var(--gaming-gold), 0 0 0 4px var(--gaming-gold);
        }
        .feature-icon {
            font-size: 2.5rem;
            margin-bottom: 1rem;
            color: var(--gaming-gold);
            text-shadow: 0 2px 8px var(--gaming-orange);
        }
        .bg-light {
            background: var(--gaming-dark) !important;
            color: var(--gaming-beige) !important;
        }
        h2, h3, h4 {
            color: var(--gaming-gold);
            text-shadow: 0 2px 8px var(--gaming-orange);
        }
        .card {
            background: var(--gaming-dark);
            color: var(--gaming-beige);
            border-radius: 1rem;
        }
        .form-control, .form-control:focus {
            background: var(--gaming-teal-dark);
            color: var(--gaming-beige);
            border: 1px solid var(--gaming-gold);
        }
        .footer {
            background: linear-gradient(90deg, var(--gaming-dark), var(--gaming-red-dark));
            color: var(--gaming-beige);
            padding: 2rem 0 0.5rem 0;
            text-align: center;
            border-top: 2px solid var(--gaming-gold);
            margin-top: 3rem;
        }
        /* Glow effect for gaming vibe */
        .glow {
            text-shadow: 0 0 8px var(--gaming-gold), 0 0 16px var(--gaming-orange);
        }
    </style>
</head>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="#">ES LEAGUE</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="#features">Features</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#about">About</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#contact">Contact</a>
                    </li>
                    <li class="nav-item">
                    <a class="nav-link btn btn-primary text-white px-3 ms-2" href="@Url.Action("SampleLogin", "Account")">Login</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <section class="hero text-center">
        <div class="container">
            <h1 class="display-4 fw-bold mb-4">Esports Tournament Bracketing System</h1>
            <p class="lead mb-5">Create and manage your own esports tournaments with our easy-to-use bracketing system.</p>
            <a href="@Url.Action("SampleLogin", "Account")" class="btn btn-primary btn-lg px-5 py-3">Get Started</a>
        </div>
    </section>

    <section class="container mb-5" id="features">
        <h2 class="text-center mb-5">Features</h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card feature-card p-4">
                    <div class="text-center">
                        <div class="feature-icon">🏆</div>
                        <h3>Tournament Creation</h3>
                        <p>Create custom tournaments with flexible participant limits and game settings.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card feature-card p-4">
                    <div class="text-center">
                        <div class="feature-icon">📊</div>
                        <h3>Automatic Brackets</h3>
                        <p>Our system automatically generates tournament brackets based on participant count.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card feature-card p-4">
                    <div class="text-center">
                        <div class="feature-icon">👥</div>
                        <h3>User Accounts</h3>
                        <p>Secure user authentication system for tournament creators and participants.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card feature-card p-4">
                    <div class="text-center">
                        <div class="feature-icon">🎮</div>
                        <h3>Game Agnostic</h3>
                        <p>Support for any type of esports game or competition format.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card feature-card p-4">
                    <div class="text-center">
                        <div class="feature-icon">🔄</div>
                        <h3>Real-time Updates</h3>
                        <p>Tournament brackets update in real-time as matches are completed.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card feature-card p-4">
                    <div class="text-center">
                        <div class="feature-icon">📱</div>
                        <h3>Mobile Friendly</h3>
                        <p>Access tournaments from any device with our responsive design.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="bg-light py-5" id="about">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6">
                    <h2 class="mb-4">About Our Platform</h2>
                    <p class="lead">Our Esports Tournament Bracketing System is designed to make organizing competitive gaming events simple and efficient.</p>
                    <p>Whether you're running a small community tournament or a large-scale competition, our platform provides all the tools you need to create, manage, and track your tournaments from start to finish.</p>
                    <p>With features like first-come-first-serve seeding, automatic bracket generation, and real-time updates, you can focus on what matters most - the competition itself.</p>
                </div>
                <div class="col-lg-6">
                    <img src="https://placehold.co/600x400/212529/FFFFFF?text=Tournament+Brackets" alt="Tournament Bracket Example" class="img-fluid rounded shadow">
                </div>
            </div>
        </div>
    </section>

    <section class="container py-5" id="contact">
        <h2 class="text-center mb-5">Contact Us</h2>
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card shadow">
                    <div class="card-body p-4">
                        <form>
                            <div class="mb-3">
                                <label for="name" class="form-label">Name</label>
                                <input type="text" class="form-control" id="name" required>
                            </div>
                            <div class="mb-3">
                                <label for="email" class="form-label">Email</label>
                                <input type="email" class="form-control" id="email" required>
                            </div>
                            <div class="mb-3">
                                <label for="message" class="form-label">Message</label>
                                <textarea class="form-control" id="message" rows="4" required></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary">Send Message</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <footer class="bg-dark text-white py-4 mt-5">
        <div class="container text-center">
            <p> 2023 Esports Tournament Bracketing System. All rights reserved.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>